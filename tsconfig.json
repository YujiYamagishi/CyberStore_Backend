{
  "include": ["src/**/*", "prisma/**/*.ts"], 
  "files": ["src/types/index.d.ts"], 
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "moduleResolution": "node",
    
    "module": "commonjs",
    "target": "esnext",
    "types": ["node"],

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true, 

    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}